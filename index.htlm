<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#C84B31">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Délices Maison">
  <meta name="description" content="Vos recettes de cuisine, toujours avec vous">
  <title>Délices Maison</title>
  <link rel="manifest" href="manifest.json">
  <link rel="apple-touch-icon" href="icons/icon-192.png">
  <link rel="icon" type="image/png" href="icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>

<body class="light-mode">

  <!-- ===== HEADER ===== -->
  <header class="app-header" id="appHeader">
    <button id="btnBack" class="btn-icon hidden" onclick="goBack()">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
    </button>
    <div class="header-brand" id="headerBrand">
      <span class="brand-icon">🍽️</span>
      <span class="brand-name">Délices Maison</span>
    </div>
    <div id="headerTitle" class="header-page-title hidden"></div>
    <div class="header-actions">
      <button id="btnTheme" class="btn-icon" onclick="toggleTheme()" title="Changer le thème">
        <svg id="iconSun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="iconMoon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button class="btn-icon" onclick="navigateTo('search')" title="Rechercher">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ===== CONTENU PRINCIPAL ===== -->
  <main id="appContent">

    <!-- ── VUE : ACCUEIL ── -->
    <section id="viewHome" class="view active">

      <!-- Bannière hero -->
      <div class="hero-banner">
        <div class="hero-overlay"></div>
        <div class="hero-shapes">
          <div class="hero-shape shape-1"></div>
          <div class="hero-shape shape-2"></div>
          <div class="hero-shape shape-3"></div>
        </div>
        <div class="hero-content">
          <p class="hero-sub">Bienvenue, Chk 👋</p>
          <h2 class="hero-title">Vos recettes,<br>toujours avec vous</h2>
          <button class="btn-hero" onclick="navigateTo('add')">
            <span>+</span> Nouvelle recette
          </button>
        </div>
        <div class="hero-wave">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
            <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="var(--bg-color)"/>
          </svg>
        </div>
      </div>

      <!-- Catégories -->
      <div class="section-header">
        <h3 class="section-title">Catégories</h3>
      </div>
      <div class="categories-scroll" id="categoriesScroll"></div>

      <!-- Dernières recettes -->
      <div class="section-header">
        <h3 class="section-title">Mes recettes</h3>
        <span class="recipe-count" id="recipeCount"></span>
      </div>
      <div class="recipes-grid" id="recipesGrid">
        <div class="empty-state" id="emptyState">
          <div class="empty-icon">🥄</div>
          <p>Aucune recette pour l'instant</p>
          <button class="btn-primary" onclick="navigateTo('add')">Ajouter ma première recette</button>
        </div>
      </div>
    </section>

    <!-- ── VUE : CATÉGORIE FILTRÉE ── -->
    <section id="viewCategory" class="view">
      <div class="section-header">
        <h3 class="section-title" id="categoryViewTitle"></h3>
      </div>
      <div class="recipes-grid" id="categoryGrid"></div>
    </section>

    <!-- ── VUE : FICHE RECETTE ── -->
    <section id="viewRecipe" class="view">
      <div id="recipeDetail"></div>
    </section>

    <!-- ── VUE : FAVORIS ── -->
    <section id="viewFavorites" class="view">
      <div class="section-header">
        <h3 class="section-title">❤️ Mes favoris</h3>
      </div>
      <div class="recipes-grid" id="favoritesGrid">
        <div class="empty-state">
          <div class="empty-icon">💔</div>
          <p>Aucune recette en favori</p>
        </div>
      </div>
    </section>

    <!-- ── VUE : RECHERCHE ── -->
    <section id="viewSearch" class="view">
      <div class="search-container">
        <div class="search-input-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="text" id="searchInput" placeholder="Titre, ingrédient, catégorie..." autocomplete="off" oninput="searchRecipes(this.value)">
          <button id="btnClearSearch" class="hidden" onclick="clearSearch()">✕</button>
        </div>
      </div>
      <div class="section-header" id="searchResultHeader" style="display:none">
        <h3 class="section-title" id="searchResultTitle"></h3>
      </div>
      <div class="recipes-grid" id="searchGrid">
        <div class="search-hint">
          <div class="empty-icon">🔍</div>
          <p>Tapez pour rechercher une recette</p>
        </div>
      </div>
    </section>

    <!-- ── VUE : AJOUTER / MODIFIER ── -->
    <section id="viewAdd" class="view">
      <div class="form-container">
        <h3 class="form-title" id="formTitle">✨ Nouvelle recette</h3>

        <!-- Photo -->
        <div class="form-group">
          <label class="form-label">Photo de la recette</label>
          <div class="image-picker" id="imagePicker" onclick="document.getElementById('imageInput').click()">
            <div class="image-preview" id="imagePreview">
              <div class="image-placeholder">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span>Ajouter une photo</span>
              </div>
            </div>
            <input type="file" id="imageInput" accept="image/*" style="display:none" onchange="previewImage(this)">
          </div>
        </div>

        <!-- Titre -->
        <div class="form-group">
          <label class="form-label">Titre de la recette *</label>
          <input type="text" id="fTitre" class="form-input" placeholder="Ex : Tarte aux pommes caramélisée...">
        </div>

        <!-- Catégorie -->
        <div class="form-group">
          <label class="form-label">Catégorie *</label>
          <select id="fCategorie" class="form-input">
            <option value="">-- Choisir une catégorie --</option>
            <option value="plats">🍽️ Plats</option>
            <option value="desserts">🍰 Desserts</option>
            <option value="patisserie">🥐 Pâtisserie</option>
            <option value="gouter">🧁 Goûter</option>
            <option value="boissons">🥤 Boissons</option>
            <option value="rapide">⚡ Rapide</option>
            <option value="famille">👨‍👩‍👧 Famille</option>
          </select>
        </div>

        <!-- Temps & Portions -->
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Préparation (min)</label>
            <input type="number" id="fPrep" class="form-input" placeholder="15" min="0">
          </div>
          <div class="form-group">
            <label class="form-label">Cuisson (min)</label>
            <input type="number" id="fCuisson" class="form-input" placeholder="30" min="0">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Portions</label>
            <input type="number" id="fPortions" class="form-input" placeholder="4" min="1" value="4">
          </div>
          <div class="form-group">
            <label class="form-label">Difficulté</label>
            <select id="fDifficulte" class="form-input">
              <option value="facile">😊 Facile</option>
              <option value="moyen">😐 Moyen</option>
              <option value="difficile">😤 Difficile</option>
            </select>
          </div>
        </div>

        <!-- Ingrédients -->
        <div class="form-group">
          <label class="form-label">Ingrédients</label>
          <div id="ingredientsList" class="dynamic-list"></div>
          <button type="button" class="btn-add-item" onclick="addIngredient()">
            <span>+</span> Ajouter un ingrédient
          </button>
        </div>

        <!-- Étapes -->
        <div class="form-group">
          <label class="form-label">Étapes de préparation</label>
          <div id="etapesList" class="dynamic-list"></div>
          <button type="button" class="btn-add-item" onclick="addEtape()">
            <span>+</span> Ajouter une étape
          </button>
        </div>

        <!-- Tags -->
        <div class="form-group">
          <label class="form-label">Tags</label>
          <div class="tags-selector" id="tagsSelector">
            <button type="button" class="tag-btn" data-tag="rapide">⚡ Rapide</button>
            <button type="button" class="tag-btn" data-tag="economique">💰 Économique</button>
            <button type="button" class="tag-btn" data-tag="famille">👨‍👩‍👧 Famille</button>
            <button type="button" class="tag-btn" data-tag="fete">🎉 Fête</button>
            <button type="button" class="tag-btn" data-tag="healthy">🥗 Healthy</button>
            <button type="button" class="tag-btn" data-tag="enfants">👶 Enfants</button>
          </div>
        </div>

        <!-- Note personnelle -->
        <div class="form-group">
          <label class="form-label">Note personnelle</label>
          <textarea id="fNote" class="form-input form-textarea" placeholder="Astuces, variantes, souvenirs..."></textarea>
        </div>

        <input type="hidden" id="fId">

        <!-- Boutons -->
        <div class="form-actions">
          <button class="btn-secondary" onclick="goBack()">Annuler</button>
          <button class="btn-primary" onclick="saveRecipe()">💾 Enregistrer</button>
        </div>

      </div>
    </section>

  </main>

  <!-- ===== NAVIGATION BAS ===== -->
  <nav class="bottom-nav">
    <button class="nav-btn active" id="nav-home" onclick="navigateTo('home')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>Accueil</span>
    </button>
    <button class="nav-btn" id="nav-search" onclick="navigateTo('search')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <span>Recherche</span>
    </button>
    <button class="nav-btn nav-add" onclick="navigateTo('add')">
      <div class="nav-add-circle">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </div>
    </button>
    <button class="nav-btn" id="nav-favorites" onclick="navigateTo('favorites')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span>Favoris</span>
    </button>
    <button class="nav-btn" id="nav-add-hidden" style="display:none"></button>
  </nav>

  <!-- ===== TOAST NOTIFICATION ===== -->
  <div id="toast" class="toast"></div>

  <!-- ===== MODAL CONFIRMATION ===== -->
  <div id="modal" class="modal-overlay hidden">
    <div class="modal-box">
      <p class="modal-text" id="modalText">Supprimer cette recette ?</p>
      <div class="modal-actions">
        <button class="btn-secondary" onclick="closeModal()">Annuler</button>
        <button class="btn-danger" id="modalConfirmBtn">Supprimer</button>
      </div>
    </div>
  </div>

  <script src="script.js"></script>
</body>
</html>
